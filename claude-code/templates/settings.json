{
  "cleanupPeriodDays": 3650,
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NoProfile -WindowStyle Hidden -File \"__CLAUDE_PS1_PATH__\"",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ]
  }
}
